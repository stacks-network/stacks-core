#!/usr/bin/env bash
set -euo pipefail

# --- Changelog fragment check ---
# Look for staged fragment files in changelog.d/ or stacks-signer/changelog.d/,
# ignoring READMEs (which aren't fragments).
STAGED_FRAGMENTS=$(git diff --cached --name-only -- 'changelog.d/*' 'stacks-signer/changelog.d/*' \
  | grep -vE 'README\.md$' || true)

if [[ -z "$STAGED_FRAGMENTS" ]]; then
  SCRIPT="$(git rev-parse --show-toplevel)/contrib/create-changelog-fragment.sh"
  if [[ -x "$SCRIPT" ]]; then
    # Reconnect stdin to the terminal for interactive prompts
    exec < /dev/tty
    "$SCRIPT"
    exec <&-
  fi
fi

# Only run Rust checks if there are staged Rust changes
if ! git diff --cached --name-only -- '*.rs' | grep -q . ; then
  exit 0
fi

echo "▶ rustfmt (fmt-stacks alias, check only)…"
if ! cargo +nightly fmt-stacks --check
then
  echo
  echo "✖ Formatting issues detected."
  echo "  Fix with:"
  echo "    cargo +nightly fmt-stacks"
  exit 1
fi

echo "▶ clippy (clippy-stacks alias)…"
if ! cargo clippy-stacks
then
  echo
  echo "✖ Clippy (stacks) failed."
  exit 1
fi

echo "▶ clippy (clippy-stackslib alias)…"
if ! cargo clippy-stackslib
then
  echo
  echo "✖ Clippy (stackslib) failed."
  exit 1
fi

echo "✓ Pre-commit checks passed."
